# ==============================================
# CONTRACTORY — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.

# ─── App ───────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (required) ───────────────────
# Get from: https://supabase.com/dashboard → your project → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Wallet Connect (required for mobile wallets) ──
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ─── Arc Network ───────────────────────────
# Defaults work for Arc Testnet — only change for custom RPC
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# ─── AI (optional) ─────────────────────────
# Required only for AI Assistant features
ANTHROPIC_API_KEY=sk-ant-...

# ─── Feature Flags ─────────────────────────
NEXT_PUBLIC_FF_BRIDGE=true
NEXT_PUBLIC_FF_SWAP=true
NEXT_PUBLIC_FF_AI_ASSISTANT=true
NEXT_PUBLIC_FF_AGENT_STUDIO=true
