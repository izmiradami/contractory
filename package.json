    "@typescript-eslint/parser": "8.19.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "2.1.8",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.0",
    "eslint-plugin-import": "2.31.0",
    "hardhat": "2.22.17",
    "husky": "9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "15.3.0",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "supabase": "1.223.10",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
