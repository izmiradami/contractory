{
  "name": "contractory",
  "version": "1.0.0",
  "private": true,
  "description": "The Developer Operating System for Arc blockchain",
  "author": "Contractory Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > types/database.ts",
    "hardhat:compile": "hardhat compile",
    "hardhat:test": "hardhat test",
    "prepare": "husky"
  },
  "dependencies": {
    "@circle-fin/adapter-viem-v2": "latest",
    "@circle-fin/unified-balance-kit": "latest",
    "@hookform/resolvers": "3.9.1",
