    "framer-motion": "11.15.0",
    "geist": "^1.7.2",
    "immer": "10.1.1",
    "lucide-react": "0.469.0",
    "nanoid": "5.0.9",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.54.2",
    "siwe": "^3.0.0",
    "solc": "^0.8.35",
    "sonner": "1.7.2",
    "tailwind-merge": "2.6.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "typescript": "5.7.2",
    "viem": "^2.21.19",
